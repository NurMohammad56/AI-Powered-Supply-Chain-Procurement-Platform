# =============================================================================
# AI-Powered Supply Chain Platform - Backend Environment
# Copy to `.env` and fill in real values for local development.
# Never commit `.env` with real secrets.
# =============================================================================

# ----- Runtime -----
NODE_ENV=development                         # development | staging | production
PORT=4000                                    # API HTTP port
LOG_LEVEL=debug                              # trace | debug | info | warn | error | fatal
GIT_SHA=local                                # injected by CI in non-local envs

# ----- MongoDB -----
MONGO_URI=mongodb://127.0.0.1:27017/scp_dev  # Atlas SRV string in non-local envs
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=5

# ----- Redis (Upstash in production; localhost for dev) -----
REDIS_URL=redis://127.0.0.1:6379
REDIS_TLS=false                              # true for Upstash

# ----- JWT -----
# Distinct secrets for access vs refresh (SDD §9.1) - 32+ random bytes each.
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_TTL=15m                           # 15 minutes per SDD
JWT_REFRESH_TTL=7d                           # 7 days per SDD
JWT_ISSUER=scp-platform
JWT_AUDIENCE=scp-platform-clients

# ----- bcrypt -----
BCRYPT_COST=12                               # NFR-SEC-01 minimum

# ----- CORS -----
CORS_ORIGINS=http://localhost:3000           # comma-separated

# ----- Cookie (refresh token storage) -----
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                          # true in staging/production

# ----- Rate limiting -----
RATE_LIMIT_UNAUTH_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=600
RATE_LIMIT_TENANT_PER_MIN=6000

# ----- Email (Resend) -----
RESEND_API_KEY=re_changeme
EMAIL_FROM=noreply@factory.bd
EMAIL_REPLY_TO=support@factory.bd

# ----- AI providers (used in later prompts) -----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_PER_CALL_TIMEOUT_MS=30000
AI_FAILURE_THRESHOLD=3
AI_COOLDOWN_MS=60000

# ----- Object storage (Cloudflare R2 - S3 compatible; used in later prompts) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scp-dev
R2_ENDPOINT=
R2_PUBLIC_URL_TTL_SECONDS=300

# ----- Payments (used in billing prompt) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

# ----- Observability -----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Frontend URL (for password-reset, invitations) -----
FRONTEND_BASE_URL=http://localhost:3000
